# AI Providers (at least one required)
# Modal cloud Ollama (GPU in cloud — RECOMMENDED for production/selling)
# Deploy with: modal deploy backend/modal_ollama.py
MODAL_OLLAMA_URL=https://your-modal-app.modal.run
MODAL_OLLAMA_MODEL=llava-llama3

# Local Ollama (for self-hosted)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llava-llama3

# Cloud AI APIs
KIMI_API_KEY=sk-kimi-your-key-here
MINIMAX_API_KEY=sk-api-your-key-here
