<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AIMS VISION PRO — Radiology Workstation</title>
<style>
:root {
  --bg: #06060a; --panel: #0d0d18; --border: #1a1a30;
  --accent: #4ade80; --gold: #c9a84c; --text: #d4d4d8; --sub: #71717a;
  --danger: #ef4444; --blue: #60a5fa; --purple: #a78bfa; --orange: #fb923c;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:system-ui, sans-serif; min-height:100vh; }

/* Progress Bar */
.progress { display:flex; background:var(--panel); border-bottom:1px solid var(--border); padding:0; }
.progress .step { flex:1; padding:14px 16px; text-align:center; font-size:11px; color:var(--sub); border-bottom:3px solid transparent; transition:all .3s; cursor:default; }
.progress .step.active { color:var(--accent); border-bottom-color:var(--accent); }
.progress .step.done { color:var(--blue); border-bottom-color:var(--blue); }
.progress .step .num { display:inline-block; width:22px; height:22px; border-radius:50%; border:2px solid var(--sub); line-height:18px; margin-right:6px; font-size:11px; font-weight:700; }
.progress .step.active .num { border-color:var(--accent); background:var(--accent); color:#000; }
.progress .step.done .num { border-color:var(--blue); background:var(--blue); color:#000; }

/* Main */
main { max-width:900px; margin:0 auto; padding:32px 24px; }
.step-panel { display:none; }
.step-panel.active { display:block; }

/* Headers */
h1 { font-size:24px; margin-bottom:4px; }
h1 span { color:var(--accent); }
.subtitle { color:var(--sub); font-size:13px; margin-bottom:32px; }

/* Cards */
.card { background:var(--panel); border:1px solid var(--border); border-radius:12px; padding:24px; margin-bottom:20px; }
.card h2 { font-size:13px; color:var(--sub); text-transform:uppercase; letter-spacing:1px; margin-bottom:16px; }
.card h3 { font-size:12px; color:var(--blue); margin-bottom:8px; }

/* Upload Zones */
.upload-zone { border:2px dashed var(--border); border-radius:12px; padding:40px; text-align:center; cursor:pointer; transition:all .2s; margin-bottom:12px; }
.upload-zone:hover, .upload-zone.dragover { border-color:var(--accent); background:rgba(74,222,128,.03); }
.upload-zone .icon { font-size:36px; margin-bottom:8px; }
.upload-zone p { font-size:13px; color:var(--sub); }
.upload-zone .hint { font-size:10px; color:var(--sub); margin-top:4px; }

/* Camera Capture */
.camera-area { position:relative; border-radius:12px; overflow:hidden; margin-bottom:12px; }
.camera-area video { width:100%; border-radius:12px; }
.camera-area .capture-btn { position:absolute; bottom:16px; left:50%; transform:translateX(-50%); padding:12px 28px; border-radius:24px; background:var(--accent); color:#000; border:none; font-weight:700; cursor:pointer; }

/* Multi-file list */
.file-list { margin-top:8px; }
.file-item { display:flex; align-items:center; gap:10px; padding:8px 12px; background:var(--bg); border:1px solid var(--border); border-radius:8px; margin-bottom:6px; font-size:12px; }
.file-item .name { flex:1; }
.file-item .size { color:var(--sub); font-size:11px; }
.file-item .remove { color:var(--danger); cursor:pointer; font-size:14px; }

/* Buttons */
.btn { padding:10px 20px; border-radius:8px; border:none; font-size:13px; font-weight:600; cursor:pointer; transition:all .2s; }
.btn:disabled { opacity:0.4; cursor:not-allowed; }
.btn-primary { background:var(--accent); color:#000; }
.btn-primary:hover:not(:disabled) { opacity:0.85; }
.btn-secondary { background:var(--border); color:var(--text); }
.btn-blue { background:var(--blue); color:#000; }
.btn-purple { background:var(--purple); color:#000; }
.btn-danger { background:var(--danger); color:#fff; }
.btn-row { display:flex; gap:10px; margin-top:16px; flex-wrap:wrap; }

/* Forms */
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.form-group { display:flex; flex-direction:column; gap:4px; }
.form-group label { font-size:10px; color:var(--sub); text-transform:uppercase; letter-spacing:1px; }
.form-group input, .form-group textarea, .form-group select {
  background:var(--bg); border:1px solid var(--border); border-radius:6px;
  padding:10px 12px; color:var(--text); font-size:13px; outline:none;
}
.form-group input:focus, .form-group textarea:focus { border-color:var(--accent); }
.form-group textarea { min-height:80px; resize:vertical; font-family:inherit; }

/* Results */
.result-box { background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:16px; margin-bottom:12px; }
.result-box .label { font-size:10px; color:var(--sub); text-transform:uppercase; margin-bottom:8px; }
.result-box .value { font-size:12px; line-height:1.6; white-space:pre-wrap; }
.findings-list { max-height:300px; overflow-y:auto; }
.finding-item { background:var(--bg); border-left:3px solid var(--accent); padding:10px 14px; margin-bottom:8px; border-radius:0 8px 8px 0; }
.finding-item .idx { font-size:10px; color:var(--sub); }
.finding-item .content { font-size:12px; line-height:1.5; white-space:pre-wrap; margin-top:4px; }

/* Report page */
.report { background:#fff; color:#111; padding:40px; font-family:Georgia,serif; font-size:12px; line-height:1.7; border-radius:8px; max-height:70vh; overflow-y:auto; }
.report h1 { font-size:20px; text-align:center; color:#111; }
.report .meta { display:flex; justify-content:space-between; font-size:10px; color:#666; margin:16px 0; border-bottom:1px solid #ccc; padding-bottom:10px; }
.report .section { margin:12px 0; white-space:pre-wrap; }
.report .footer { margin-top:32px; border-top:1px solid #ccc; padding-top:10px; font-size:9px; color:#999; text-align:center; }

/* Dictation */
.mic-btn { padding:8px 20px; border-radius:20px; border:none; font-size:12px; font-weight:600; cursor:pointer; }
.mic-btn.off { background:var(--border); color:var(--sub); }
.mic-btn.on { background:var(--danger); color:#fff; animation:pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.6} }

/* Loading */
.loading { text-align:center; padding:30px; display:none; }
.loading.show { display:block; }
.spinner { width:36px; height:36px; border:3px solid var(--border); border-top-color:var(--accent); border-radius:50%; animation:spin 1s linear infinite; margin:0 auto 12px; }
@keyframes spin { to { transform:rotate(360deg); } }

/* Status */
.status-bar { background:var(--panel); border-top:1px solid var(--border); padding:10px 24px; font-size:11px; color:var(--sub); display:flex; justify-content:space-between; align-items:center; position:fixed; bottom:0; left:0; right:0; }
.toast { position:fixed; bottom:60px; right:24px; background:var(--accent); color:#000; padding:12px 24px; border-radius:8px; font-size:13px; font-weight:600; z-index:300; opacity:0; transition:opacity .3s; pointer-events:none; }
.toast.show { opacity:1; }

/* Tabs */
.tabs { display:flex; gap:0; margin-bottom:16px; }
.tab { padding:8px 16px; font-size:11px; color:var(--sub); border-bottom:2px solid transparent; cursor:pointer; }
.tab.active { color:var(--accent); border-bottom-color:var(--accent); }

/* History */
.history-table { width:100%; border-collapse:collapse; font-size:11px; }
.history-table th { text-align:left; padding:8px 12px; color:var(--sub); border-bottom:1px solid var(--border); text-transform:uppercase; font-size:10px; }
.history-table td { padding:8px 12px; border-bottom:1px solid var(--border); }
.history-table tr:hover { background:rgba(255,255,255,.02); }
.history-table .id { color:var(--accent); cursor:pointer; }
.search-bar { display:flex; gap:8px; margin-bottom:16px; }
.search-bar input { flex:1; background:var(--bg); border:1px solid var(--border); border-radius:6px; padding:8px 12px; color:var(--text); font-size:12px; }
</style>
</head>
<body>

<!-- Progress -->
<div class="progress" id="progress">
  <div class="step active" data-step="1"><span class="num">1</span>Prescription</div>
  <div class="step" data-step="2"><span class="num">2</span>Review & Confirm</div>
  <div class="step" data-step="3"><span class="num">3</span>Images</div>
  <div class="step" data-step="4"><span class="num">4</span>AI Analysis</div>
  <div class="step" data-step="5"><span class="num">5</span>Generate Note</div>
  <div style="flex:0;padding:14px 20px;display:flex;gap:16px;align-items:center">
    <span style="cursor:pointer;color:var(--blue);font-size:11px" onclick="window.open('http://localhost:3003','_blank')">🏥 EHR</span>
    <span style="cursor:pointer;color:var(--sub);font-size:11px" onclick="showHistory()">📋 History</span>
  </div>
</div>

<main>
  <!-- STEP 1: Prescription Capture -->
  <div class="step-panel active" id="step1">
    <h1><span>AIMS</span> VISION PRO</h1>
    <p class="subtitle">Step 1 — Capture the prescription or referral order</p>

    <!-- AIMS Login -->
    <div class="card" id="loginCard" style="border-color:var(--blue);background:rgba(96,165,250,.03)">
      <h2 style="color:var(--blue)">🔐 AIMS Login — Link to Your Account</h2>
      <div style="display:flex;gap:10px;align-items:end;flex-wrap:wrap">
        <div class="form-group" style="flex:1"><label>Username</label><input id="loginUser" placeholder="doctor" style="background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px;color:var(--text);font-size:12px"></div>
        <div class="form-group" style="flex:1"><label>Password</label><input id="loginPass" type="password" placeholder="••••••••" style="background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px;color:var(--text);font-size:12px"></div>
        <button class="btn btn-blue" onclick="aimsLogin()" style="margin-bottom:0">Login</button>
        <button class="btn btn-secondary" onclick="skipLogin()" style="margin-bottom:0;font-size:11px">Offline Mode</button>
      </div>
      <div id="loginStatus" style="font-size:11px;margin-top:8px;color:var(--sub)"></div>
    </div>

    <div class="card" style="border-color:var(--purple);background:rgba(167,139,250,.03)">
      <h2 style="color:var(--purple)">⚡ Quick Demo — Pre-loaded Cases</h2>
      <p style="font-size:12px;color:var(--sub);margin-bottom:12px">Skip manual steps and run a fully automated demo with mock MRI or X-ray data + 3-agent AI verification</p>
      <div id="demoCases" style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-purple" onclick="runDemo('knee_mri')">🦵 Knee MRI — Meniscus Tear</button>
        <button class="btn btn-purple" onclick="runDemo('chest_xray')">🫁 Chest X-Ray — Pneumonia</button>
      </div>
      <div class="loading" id="demoLoading" style="margin-top:16px">
        <div class="spinner"></div>
        <p id="demoStatus">Running demo pipeline...</p>
      </div>
      <div id="demoResult" style="display:none;margin-top:16px"></div>
    </div>

    <div class="card">
      <h2>📋 Upload Prescription</h2>
      <p style="font-size:12px;color:var(--sub);margin-bottom:12px">Take a photo of the prescription with your phone, or upload the referral PDF/image</p>

      <div class="tabs">
        <div class="tab active" onclick="switchTab('upload')">📤 Upload File</div>
        <div class="tab" onclick="switchTab('camera')">📸 Take Photo</div>
      </div>

      <div id="tab-upload">
        <label class="upload-zone" for="prescriptionFile">
          <div class="icon">📄</div>
          <p>Click to upload prescription</p>
          <p class="hint">PDF, JPG, PNG — photo of paper Rx, printed referral, or digital order</p>
        </label>
        <input type="file" id="prescriptionFile" accept="image/*,.pdf" style="display:none" onchange="handlePrescriptionFile(this.files[0])">
        <div class="file-list" id="prescriptionFileList"></div>
      </div>

      <div id="tab-camera" style="display:none">
        <div class="camera-area">
          <video id="cameraVideo" autoplay playsinline></video>
          <button class="capture-btn" onclick="capturePhoto()">📸 Capture Rx</button>
        </div>
        <canvas id="cameraCanvas" style="display:none"></canvas>
      </div>

      <div class="btn-row">
        <button class="btn btn-primary" id="analyzeRxBtn" disabled onclick="analyzePrescription()">🔍 Analyze Prescription</button>
      </div>
    </div>

    <div class="loading" id="step1Loading">
      <div class="spinner"></div>
      <p>Analyzing prescription with AI...</p>
    </div>
  </div>

  <!-- STEP 2: Review Prescription -->
  <div class="step-panel" id="step2">
    <h1><span>AIMS</span> VISION PRO</h1>
    <p class="subtitle">Step 2 — Review and confirm extracted information</p>

    <div class="card">
      <h2>📋 Extracted Prescription Data</h2>
      <p style="font-size:11px;color:var(--orange);margin-bottom:16px">⚠️ AI-extracted — please review and correct if needed</p>
      <div class="form-grid" id="prescriptionForm">
        <div class="form-group"><label>Exam Type</label><select id="rxExamType"><option>MRI</option><option>X-ray</option><option>CT</option><option>Ultrasound</option><option>Other</option></select></div>
        <div class="form-group"><label>Body Region</label><input id="rxBodyRegion" placeholder="e.g. Left Knee"></div>
        <div class="form-group"><label>Clinical Indication</label><input id="rxIndication" placeholder="Why exam is ordered"></div>
        <div class="form-group"><label>Suspected Diagnosis</label><input id="rxDiagnosis" placeholder="Working diagnosis"></div>
        <div class="form-group"><label>Urgency</label><select id="rxUrgency"><option>routine</option><option>urgent</option><option>stat</option></select></div>
        <div class="form-group"><label>Contrast</label><select id="rxContrast"><option>not specified</option><option>without contrast</option><option>with contrast</option><option>both</option></select></div>
        <div class="form-group" style="grid-column:1/-1"><label>Special Instructions</label><input id="rxInstructions" placeholder="Specific views, protocols, notes"></div>
        <div class="form-group"><label>Referring Physician</label><input id="rxPhysician" placeholder="Doctor name"></div>
        <div class="form-group"><label>Facility</label><input id="rxFacility" placeholder="Hospital or clinic"></div>
      </div>
      <div class="btn-row">
        <button class="btn btn-secondary" onclick="goToStep(1)">← Back</button>
        <button class="btn btn-primary" onclick="confirmPrescription()">✅ Confirm & Continue →</button>
      </div>
    </div>
  </div>

  <!-- STEP 3: Image Upload -->
  <div class="step-panel" id="step3">
    <h1><span>AIMS</span> VISION PRO</h1>
    <p class="subtitle" id="step3Subtitle">Step 3 — Upload medical images for analysis</p>

    <div class="card">
      <h2>🔬 Medical Images</h2>
      <p style="font-size:12px;color:var(--sub);margin-bottom:12px">
        Upload MRI slices, X-ray images, or CT scans. Multi-file supported.
      </p>

      <label class="upload-zone" for="imageFiles">
        <div class="icon">🩻</div>
        <p>Click to upload images</p>
        <p class="hint">Supports multi-file upload — select all MRI slices at once. JPG, PNG, DICOM, up to 100MB each</p>
      </label>
      <input type="file" id="imageFiles" accept="image/*,.dcm" multiple style="display:none" onchange="handleImageFiles(this.files)">
      <div class="file-list" id="imageFileList"></div>

      <p style="font-size:11px;color:var(--sub);margin-top:8px">
        Prescription context: <span id="rxContext" style="color:var(--blue)"></span>
      </p>

      <div class="btn-row">
        <button class="btn btn-secondary" onclick="goToStep(2)">← Back</button>
        <button class="btn btn-primary" id="analyzeImagesBtn" disabled onclick="analyzeImages()">🔬 Analyze Images</button>
      </div>
    </div>

    <div class="loading" id="step3Loading">
      <div class="spinner"></div>
      <p>Analyzing images with llava:13b...</p>
      <p style="font-size:11px;color:var(--sub)" id="step3Progress"></p>
    </div>
  </div>

  <!-- STEP 4: AI Analysis + Correlation -->
  <div class="step-panel" id="step4">
    <h1><span>AIMS</span> VISION PRO</h1>
    <p class="subtitle">Step 4 — AI findings + prescription correlation</p>

    <div class="card">
      <h2>🧠 AI Image Analysis</h2>
      <div class="findings-list" id="findingsDisplay"></div>
    </div>

    <div class="card" id="correlationCard" style="display:none">
      <h2>🔗 Prescription ↔ Image Correlation</h2>
      <div class="result-box"><div class="value" id="correlationDisplay"></div></div>
    </div>

    <div class="card">
      <h2>📚 ACR Criteria (RAG)</h2>
      <div id="ragDisplay"></div>
    </div>

    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goToStep(3)">← Back</button>
      <button class="btn btn-purple" id="correlateBtn" onclick="runCorrelation()">🔗 Run Correlation</button>
      <button class="btn btn-primary" onclick="goToStep(5)">📝 Continue to Note →</button>
    </div>
  </div>

  <!-- STEP 5: Generate Medical Note -->
  <div class="step-panel" id="step5">
    <h1><span>AIMS</span> VISION PRO</h1>
    <p class="subtitle">Step 5 — Doctor's notes + final medical report</p>

    <div class="card">
      <h2>🎤 Doctor's Dictation</h2>
      <div style="display:flex;gap:12px;align-items:center;margin-bottom:12px">
        <button class="mic-btn off" id="micBtn" onclick="toggleMic()">🎤 Start Dictation</button>
        <select id="noteTemplate" style="background:var(--bg);border:1px solid var(--border);border-radius:6px;padding:8px;color:var(--text);font-size:12px">
          <option value="DEFAULT">Standard Report</option>
          <option value="DETAILED">Detailed Report</option>
          <option value="BRIEF">Brief Summary</option>
        </select>
      </div>
      <textarea id="doctorNotes" placeholder="Type your notes here, or use voice dictation..." style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:16px;color:var(--text);font-size:13px;min-height:150px;resize:vertical;outline:none;font-family:inherit;line-height:1.6"></textarea>
    </div>

    <div class="btn-row">
      <button class="btn btn-secondary" onclick="goToStep(4)">← Back</button>
      <button class="btn btn-primary" id="generateNoteBtn" onclick="generateNote()">📋 Generate Medical Note</button>
    </div>

    <div class="loading" id="step5Loading">
      <div class="spinner"></div>
      <p>Generating medical note with gemma4...</p>
    </div>

    <div class="card" id="reportCard" style="display:none">
      <h2>📄 Final Medical Report</h2>
      <div class="report" id="reportContent"></div>
      <div class="btn-row">
        <button class="btn btn-blue" onclick="printReport()">🖨 Print Report</button>
        <button class="btn btn-danger" onclick="resetAll()">🔄 New Case</button>
      </div>
    </div>
  </div>

  <!-- HISTORY PANEL -->
  <div class="step-panel" id="historyPanel">
    <h1><span>AIMS</span> VISION PRO</h1>
    <p class="subtitle">Report History — Searchable Archive</p>
    <div class="card">
      <div class="search-bar">
        <input placeholder="Search reports..." id="histSearch" onkeyup="searchHistory()">
        <button class="btn btn-secondary" onclick="loadHistory()">🔄 Refresh</button>
      </div>
      <div id="historyStats" style="font-size:11px;color:var(--sub);margin-bottom:12px"></div>
      <table class="history-table">
        <thead><tr><th>ID</th><th>Patient</th><th>Exam</th><th>Preview</th><th>Date</th></tr></thead>
        <tbody id="historyBody"><tr><td colspan="5" style="text-align:center;color:var(--sub)">Loading...</td></tr></tbody>
      </table>
    </div>
  </div>
</main>

<div class="status-bar">
  <span id="statusText">Ready — Start by uploading a prescription</span>
  <span style="color:var(--sub)">Session: <span id="sessionIdDisplay">—</span></span>
</div>
<div class="toast" id="toast"></div>

<script>
// ═══════════ STATE ═══════════
let sessionId = null;
let prescriptionData = null;
let imageFindings = null;
let ragSources = null;
let correlationData = null;
let isRecording = false;
let recognition = null;
let selectedPrescriptionFile = null;
let selectedImageFiles = [];

// ═══════════ NAVIGATION ═══════════
function goToStep(n) {
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.getElementById(`step${n}`).classList.add('active');
  document.querySelectorAll('.progress .step').forEach(s => {
    const sn = parseInt(s.dataset.step);
    s.classList.remove('active', 'done');
    if (sn === n) s.classList.add('active');
    if (sn < n) s.classList.add('done');
  });
}

function setStatus(msg) { document.getElementById('statusText').textContent = msg; }
function toast(msg) { const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),3000); }
function switchTab(name) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('[id^="tab-"]').forEach(d => d.style.display = 'none');
  event.target.classList.add('active');
  document.getElementById(`tab-${name}`).style.display = 'block';
  if (name === 'camera') startCamera();
  else stopCamera();
}

// ═══════════ CAMERA ═══════════
let cameraStream = null;
async function startCamera() {
  try {
    cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
    document.getElementById('cameraVideo').srcObject = cameraStream;
  } catch(e) { toast('Camera access denied'); }
}
function stopCamera() {
  if (cameraStream) { cameraStream.getTracks().forEach(t => t.stop()); cameraStream = null; }
}
function capturePhoto() {
  const video = document.getElementById('cameraVideo');
  const canvas = document.getElementById('cameraCanvas');
  canvas.width = video.videoWidth; canvas.height = video.videoHeight;
  canvas.getContext('2d').drawImage(video, 0, 0);
  canvas.toBlob(blob => {
    selectedPrescriptionFile = new File([blob], 'prescription_capture.jpg', { type: 'image/jpeg' });
    document.getElementById('prescriptionFileList').innerHTML = `<div class="file-item"><span class="name">📸 Captured prescription</span><span class="size">${(blob.size/1024).toFixed(0)}KB</span></div>`;
    document.getElementById('analyzeRxBtn').disabled = false;
    toast('Photo captured!');
    stopCamera();
  }, 'image/jpeg', 0.9);
}

// ═══════════ STEP 1: PRESCRIPTION ═══════════
function handlePrescriptionFile(file) {
  if (!file) return;
  selectedPrescriptionFile = file;
  document.getElementById('prescriptionFileList').innerHTML = `<div class="file-item"><span class="name">📄 ${file.name}</span><span class="size">${(file.size/1024).toFixed(0)}KB</span></div>`;
  document.getElementById('analyzeRxBtn').disabled = false;
}

async function analyzePrescription() {
  if (!selectedPrescriptionFile) { toast('Select a prescription file first'); return; }

  document.getElementById('step1Loading').classList.add('show');
  document.getElementById('analyzeRxBtn').disabled = true;
  setStatus('Analyzing prescription...');

  const form = new FormData();
  form.append('prescription', selectedPrescriptionFile);
  if (sessionId) form.append('session_id', sessionId);

  try {
    const resp = await fetch('/api/prescription/analyze', { method:'POST', body:form });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error);

    sessionId = data.session_id;
    prescriptionData = data.prescription;
    document.getElementById('sessionIdDisplay').textContent = sessionId;

    // Fill Step 2 form
    document.getElementById('rxExamType').value = data.prescription.exam_type?.toLowerCase().includes('x-ray') ? 'X-ray' : data.prescription.exam_type?.toLowerCase().includes('ct') ? 'CT' : data.prescription.exam_type?.toLowerCase().includes('ultrasound') ? 'Ultrasound' : 'MRI';
    document.getElementById('rxBodyRegion').value = data.prescription.body_region || '';
    document.getElementById('rxIndication').value = data.prescription.clinical_indication || '';
    document.getElementById('rxDiagnosis').value = data.prescription.preliminary_diagnosis || '';
    document.getElementById('rxUrgency').value = data.prescription.urgency || 'routine';
    document.getElementById('rxContrast').value = data.prescription.contrast || 'not specified';
    document.getElementById('rxInstructions').value = data.prescription.special_instructions || '';
    document.getElementById('rxPhysician').value = data.prescription.referring_physician || '';
    document.getElementById('rxFacility').value = data.prescription.facility || '';

    goToStep(2);
    setStatus('Prescription analyzed — review the extracted data');
    toast('Prescription analyzed!');
  } catch(e) {
    setStatus('Error: ' + e.message);
    toast('Failed: ' + e.message);
  } finally {
    document.getElementById('step1Loading').classList.remove('show');
    document.getElementById('analyzeRxBtn').disabled = false;
  }
}

// ═══════════ STEP 2: CONFIRM ═══════════
function confirmPrescription() {
  prescriptionData = {
    exam_type: document.getElementById('rxExamType').value,
    body_region: document.getElementById('rxBodyRegion').value,
    clinical_indication: document.getElementById('rxIndication').value,
    preliminary_diagnosis: document.getElementById('rxDiagnosis').value,
    urgency: document.getElementById('rxUrgency').value,
    contrast: document.getElementById('rxContrast').value,
    special_instructions: document.getElementById('rxInstructions').value,
    referring_physician: document.getElementById('rxPhysician').value,
    facility: document.getElementById('rxFacility').value,
  };
  document.getElementById('rxContext').textContent = `${prescriptionData.exam_type} | ${prescriptionData.body_region} | ${prescriptionData.preliminary_diagnosis || 'no Dx'}`;
  document.getElementById('step3Subtitle').textContent = `Step 3 — Upload ${prescriptionData.exam_type} images for ${prescriptionData.body_region}`;
  goToStep(3);
  setStatus('Prescription confirmed — upload images');
}

// ═══════════ STEP 3: IMAGES ═══════════
function handleImageFiles(files) {
  selectedImageFiles = Array.from(files);
  document.getElementById('imageFileList').innerHTML = selectedImageFiles.map((f,i) => 
    `<div class="file-item"><span class="name">🩻 ${f.name}</span><span class="size">${(f.size/1024/1024).toFixed(1)}MB</span><span class="remove" onclick="removeImage(${i})">✕</span></div>`
  ).join('');
  document.getElementById('analyzeImagesBtn').disabled = selectedImageFiles.length === 0;
}
function removeImage(i) { selectedImageFiles.splice(i,1); handleImageFiles(selectedImageFiles); }

async function analyzeImages() {
  if (!selectedImageFiles.length) { toast('Select images first'); return; }
  if (!sessionId) { toast('No session — go back to Step 1'); return; }

  document.getElementById('step3Loading').classList.add('show');
  document.getElementById('analyzeImagesBtn').disabled = true;
  setStatus(`Analyzing ${selectedImageFiles.length} image(s)...`);

  const form = new FormData();
  form.append('session_id', sessionId);
  selectedImageFiles.forEach(f => form.append('images', f));

  try {
    const resp = await fetch('/api/images/analyze', { method:'POST', body:form });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error);

    imageFindings = data.findings;
    ragSources = data.rag;

    // Display findings
    document.getElementById('findingsDisplay').innerHTML = data.findings.map(f => 
      `<div class="finding-item"><div class="idx">Image ${f.index} — ${f.file_name}</div><div class="content">${f.analysis}</div></div>`
    ).join('');

    // Display RAG
    document.getElementById('ragDisplay').innerHTML = data.rag.map(r => 
      `<div class="result-box"><div class="label">${r.category} (${r.score?.toFixed(2)})</div><div class="value">${r.title}</div></div>`
    ).join('');

    goToStep(4);
    setStatus(`${data.image_count} images analyzed — run correlation next`);
    toast('Images analyzed!');
  } catch(e) {
    setStatus('Error: ' + e.message);
    toast('Failed: ' + e.message);
  } finally {
    document.getElementById('step3Loading').classList.remove('show');
    document.getElementById('analyzeImagesBtn').disabled = false;
  }
}

// ═══════════ STEP 4: CORRELATION ═══════════
async function runCorrelation() {
  if (!sessionId) return;
  document.getElementById('correlateBtn').disabled = true;
  document.getElementById('correlateBtn').textContent = '⏳ Correlating...';
  setStatus('Running correlation analysis...');

  try {
    const resp = await fetch('/api/correlate', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ session_id: sessionId })
    });
    const data = await resp.json();
    correlationData = data.correlation;
    document.getElementById('correlationDisplay').textContent = data.correlation;
    document.getElementById('correlationCard').style.display = 'block';
    setStatus('Correlation complete');
    toast('Correlation done!');
  } catch(e) {
    toast('Correlation failed: ' + e.message);
  } finally {
    document.getElementById('correlateBtn').disabled = false;
    document.getElementById('correlateBtn').textContent = '🔗 Run Correlation';
  }
}

// ═══════════ STEP 5: NOTE ═══════════
async function generateNote() {
  if (!sessionId) { toast('No active session'); return; }

  document.getElementById('step5Loading').classList.add('show');
  document.getElementById('generateNoteBtn').disabled = true;
  setStatus('Generating medical note...');

  try {
    const resp = await fetch('/api/generate-note', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        session_id: sessionId,
        doctor_notes: document.getElementById('doctorNotes').value,
        prompt_template: document.getElementById('noteTemplate').value,
      })
    });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error);

    document.getElementById('reportContent').innerHTML = data.note.replace(/\n/g, '<br>');
    document.getElementById('reportCard').style.display = 'block';
    setStatus('Medical note generated');
    toast('Report ready!');
  } catch(e) {
    toast('Failed: ' + e.message);
  } finally {
    document.getElementById('step5Loading').classList.remove('show');
    document.getElementById('generateNoteBtn').disabled = false;
  }
}

// ═══════════ DEMO RUNNER ═══════════
async function runDemo(caseId) {
  document.getElementById('demoCases').style.display = 'none';
  const loading = document.getElementById('demoLoading');
  const status = document.getElementById('demoStatus');
  const result = document.getElementById('demoResult');
  loading.classList.add('show');
  status.textContent = 'Running full demo pipeline...';

  try {
    const resp = await fetch('/api/demo/run', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ case_id: caseId })
    });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error);

    sessionId = data.session_id;
    document.getElementById('sessionIdDisplay').textContent = sessionId;

    result.style.display = 'block';
    result.innerHTML = `
      <div class="result-box">
        <div class="label">✅ Primary Report (Agent 1: Chief Radiologist — gemma4)</div>
        <div class="report" style="max-height:400px;overflow-y:auto;margin-top:8px">${data.primary_report.replace(/\n/g, '<br>')}</div>
      </div>
      <div class="result-box">
        <div class="label">📚 RAG Sources (${data.rag_sources?.length || 0} ACR criteria)</div>
        ${(data.rag_sources||[]).map(r => `<div style="font-size:11px;padding:2px 0">• [${r.category}] ${r.title} (${r.score?.toFixed(2)})</div>`).join('')}
      </div>
      <div class="btn-row">
        <button class="btn btn-blue" onclick="verifyDemo()">🔍 Run 3-Agent Verification</button>
        <button class="btn btn-secondary" onclick="resetDemo()">Reset</button>
      </div>
    `;
    status.textContent = 'Primary report ready. Run 3-agent verification.';
    setStatus('Demo loaded — ' + data.steps.findings);
  } catch(e) {
    status.textContent = 'Failed: ' + e.message;
    setStatus('Demo error');
  } finally {
    loading.classList.remove('show');
    document.getElementById('demoCases').style.display = 'flex';
  }
}

async function verifyDemo() {
  if (!sessionId) return;
  document.getElementById('demoCases').style.display = 'none';
  const loading = document.getElementById('demoLoading');
  const status = document.getElementById('demoStatus');
  loading.classList.add('show');
  status.textContent = 'Running 3-agent verification...';

  try {
    const resp = await fetch('/api/demo/verify', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ session_id: sessionId })
    });
    const data = await resp.json();
    if (!data.success) throw new Error(data.error);

    const result = document.getElementById('demoResult');
    result.innerHTML += `
      <div class="result-box" style="border-left:3px solid var(--blue)">
        <div class="label">🔍 AGENT 2 — Specialist (llama3.1:8b — ${data.agents.agent2.role})</div>
        <div class="value">${data.agents.agent2.review.replace(/\n/g, '<br>')}</div>
      </div>
      <div class="result-box" style="border-left:3px solid var(--purple)">
        <div class="label">🩺 AGENT 3 — Clinical Accuracy (qwen2.5-medical — ${data.agents.agent3.role})</div>
        <div class="value">${data.agents.agent3.review.replace(/\n/g, '<br>')}</div>
      </div>
      <div class="result-box" style="border-left:3px solid var(--accent);background:rgba(74,222,128,.03)">
        <div class="label">🏆 FINAL VERIFIED REPORT</div>
        <div class="report" style="max-height:500px;overflow-y:auto;margin-top:8px">${data.final_report.replace(/\n/g, '<br>')}</div>
      </div>
      <div class="btn-row">
        <button class="btn btn-blue" onclick="printReport()">🖨 Print Final Report</button>
        <button class="btn btn-secondary" onclick="resetDemo()">New Demo</button>
      </div>
    `;
    status.textContent = '3-agent verification complete!';
    setStatus('Final report verified by 3 AI specialists');
    toast('Verification complete!');
  } catch(e) {
    status.textContent = 'Verification failed: ' + e.message;
  } finally {
    loading.classList.remove('show');
    document.getElementById('demoCases').style.display = 'flex';
  }
}

function resetDemo() {
  document.getElementById('demoResult').style.display = 'none';
  document.getElementById('demoResult').innerHTML = '';
  document.getElementById('demoCases').style.display = 'flex';
  sessionId = null;
  fetch('/api/session/new', {method:'POST'}).then(r=>r.json()).then(d=>{ sessionId=d.session_id; document.getElementById('sessionIdDisplay').textContent=sessionId; });
}

// Voice dictation functions
function toggleMic() {
  if (isRecording) { stopDictation(); return; }
  if (!('webkitSpeechRecognition' in window)) { toast('Use Chrome for voice dictation'); return; }
  const SR = window.webkitSpeechRecognition;
  recognition = new SR();
  recognition.continuous = true; recognition.interimResults = true; recognition.lang = 'en-US';
  recognition.onresult = e => {
    let final = '';
    for (let i=e.resultIndex; i<e.results.length; i++) if (e.results[i].isFinal) final += e.results[i][0].transcript + ' ';
    if (final) document.getElementById('doctorNotes').value += final;
  };
  recognition.onend = () => { if (isRecording) recognition.start(); };
  recognition.start();
  isRecording = true;
  document.getElementById('micBtn').textContent = '⏹ Stop'; document.getElementById('micBtn').className = 'mic-btn on';
}
function stopDictation() {
  isRecording = false; if (recognition) { recognition.stop(); recognition = null; }
  document.getElementById('micBtn').textContent = '🎤 Start Dictation'; document.getElementById('micBtn').className = 'mic-btn off';
}

// ═══════════ PRINT ═══════════
function printReport() { window.print(); }
function resetAll() {
  sessionId = null; prescriptionData = null; imageFindings = null; ragSources = null; correlationData = null;
  selectedPrescriptionFile = null; selectedImageFiles = [];
  document.getElementById('sessionIdDisplay').textContent = '—';
  document.getElementById('reportCard').style.display = 'none';
  document.getElementById('correlationCard').style.display = 'none';
  document.getElementById('doctorNotes').value = '';
  document.getElementById('loginCard').style.display = document.getElementById('loginCard').style.display;
  goToStep(1); setStatus('Ready — Start by uploading a prescription'); toast('New case started');
}

// ═══════════ AIMS AUTH ═══════════
async function aimsLogin() {
  const user = document.getElementById('loginUser').value || 'doctor';
  const pass = document.getElementById('loginPass').value || 'doctor123';
  const status = document.getElementById('loginStatus');
  status.textContent = 'Connecting to AIMS...';
  status.style.color = 'var(--sub)';
  try {
    const resp = await fetch('/api/auth/login', {method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({username:user,password:pass})});
    const data = await resp.json();
    if (data.success) {
      sessionId = data.session_id;
      document.getElementById('sessionIdDisplay').textContent = sessionId;
      status.textContent = '✅ Logged in as '+data.user.name+' ('+data.user.role+')';
      status.style.color = 'var(--accent)';
      document.getElementById('loginCard').style.display = 'none';
      setStatus('Authenticated: '+data.user.name);
      toast('Logged in to AIMS');
    } else if (data.offline) {
      status.textContent = '⚠️ AIMS unreachable — working offline';
      status.style.color = 'var(--orange)';
    } else {
      status.textContent = '❌ '+(data.error||'Login failed');
      status.style.color = 'var(--danger)';
    }
  } catch(e) {
    status.textContent = '⚠️ AIMS offline — local mode';
    status.style.color = 'var(--orange)';
  }
}
function skipLogin() {
  document.getElementById('loginCard').style.display = 'none';
  setStatus('Offline mode');
}

// ═══════════ HISTORY ═══════════
function showHistory() {
  document.querySelectorAll('.step-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('historyPanel').classList.add('active');
  loadHistory();
}
async function loadHistory() {
  const search = document.getElementById('histSearch')?.value || '';
  try {
    const [reportsRes, statsRes] = await Promise.all([
      fetch(`/api/reports?search=${encodeURIComponent(search)}&limit=50`),
      fetch('/api/reports/stats')
    ]);
    const reports = await reportsRes.json();
    const stats = await statsRes.json();

    document.getElementById('historyStats').textContent = 
      `${stats.stats?.total || reports.total || 0} reports | Active since ${stats.stats?.first_report?.split('T')[0] || 'N/A'}`;

    const tbody = document.getElementById('historyBody');
    if (!reports.reports?.length) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align:center;color:var(--sub);padding:20px">No reports yet — generate your first report!</td></tr>';
      return;
    }
    tbody.innerHTML = reports.reports.map(r => `
      <tr>
        <td class="id" onclick="viewReport(${r.id})">#${r.id}</td>
        <td>${r.patient_id || '—'}</td>
        <td>${(r.file_name || '—').slice(0,30)}</td>
        <td>${r.preview || '—'}</td>
        <td>${new Date(r.created_at).toLocaleDateString()}</td>
      </tr>
    `).join('');
  } catch(e) { document.getElementById('historyBody').innerHTML = '<tr><td colspan="5" style="color:var(--danger)">Failed to load</td></tr>'; }
}
function searchHistory() { loadHistory(); }
async function viewReport(id) {
  try {
    const resp = await fetch(`/api/reports/${id}`);
    const data = await resp.json();
    if (!data.report) return toast('Report not found');
    document.getElementById('reportContent').innerHTML = (data.report.report_data || '').replace(/\n/g, '<br>');
    document.getElementById('reportCard').style.display = 'block';
    goToStep(5);
    toast(`Loaded report #${id}`);
  } catch(e) { toast('Failed to load report'); }
}

// Init
fetch('/api/session/new', {method:'POST'}).then(r=>r.json()).then(d=>{ sessionId=d.session_id; document.getElementById('sessionIdDisplay').textContent=sessionId; });
</script>
</body>
</html>
